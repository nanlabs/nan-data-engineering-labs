        {"key": "QualityLevel", "value": "Gold"},
        {"key": "Certified", "value": "true"}
      ]
    }
  ],
  "crawlers": [
    {
      "name": "sales-bronze-crawler",
      "description": "Crawls raw sales transaction data from S3",
      "role": "AWSGlueServiceRole-DataLake",
      "database_name": "dev_sales_bronze_db",
      "targets": {
        "s3_targets": [
          {
            "path": "s3://training-data-lake/bronze/sales/transactions/",
            "exclusions": [
              "*.tmp",
              "_SUCCESS",
              "_temporary/**"
            ]
          }
        ]
      },
      "schedule": "cron(0 2 * * ? *)",
      "schema_change_policy": {
        "update_behavior": "UPDATE_IN_DATABASE",
        "delete_behavior": "LOG"
      },
      "configuration": {
        "Version": 1.0,
        "CrawlerOutput": {
          "Partitions": {"AddOrUpdateBehavior": "InheritFromTable"}
        },
        "Grouping": {
          "TableGroupingPolicy": "CombineCompatibleSchemas"
        }
      },
      "recrawl_policy": {
        "recrawl_behavior": "CRAWL_NEW_FOLDERS_ONLY"
      },
      "lineage_configuration": {
        "crawler_lineage_settings": "ENABLE"
      },
      "lake_formation_configuration": {
        "use_lake_formation_credentials": true
      },
      "tags": {
        "Environment": "development",
        "DataDomain": "Sales",
        "Layer": "Bronze"
      }
    },
    {
      "name": "sales-silver-crawler",
      "description": "Crawls cleaned sales data in Silver layer",
      "role": "AWSGlueServiceRole-DataLake",
      "database_name": "dev_sales_silver_db",
      "targets": {
        "s3_targets": [
          {
            "path": "s3://training-data-lake/silver/sales/transactions/",
            "exclusions": ["_spark_metadata/**", "*.crc"]
          }
        ]
      },
      "schedule": "cron(0 4 * * ? *)",
      "schema_change_policy": {
        "update_behavior": "UPDATE_IN_DATABASE",
        "delete_behavior": "DEPRECATE_IN_DATABASE"
      },
      "configuration": {
        "Version": 1.0,
        "CrawlerOutput": {
          "Partitions": {"AddOrUpdateBehavior": "InheritFromTable"},
          "Tables": {"AddOrUpdateBehavior": "MergeNewColumns"}
        }
      },
      "recrawl_policy": {
        "recrawl_behavior": "CRAWL_NEW_FOLDERS_ONLY"
      },
      "lineage_configuration": {
        "crawler_lineage_settings": "ENABLE"
      },
      "lake_formation_configuration": {
        "use_lake_formation_credentials": true
      },
      "tags": {
        "Environment": "development",
        "DataDomain": "Sales",
        "Layer": "Silver"
      }
    }
  ],
