        {"name": "month", "type": "string", "comment": "Month from summary date"}
      ],
      "parameters": {
        "classification": "parquet",
        "compressionType": "snappy",
        "typeOfData": "file",
        "data_owner": "analytics_team@company.com",
        "update_frequency": "daily",
        "contains_pii": "false",
        "data_quality_level": "99",
        "certified": "true",
