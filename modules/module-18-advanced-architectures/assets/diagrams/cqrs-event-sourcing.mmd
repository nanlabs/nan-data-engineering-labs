graph TB
    %% CQRS + Event Sourcing Pattern

    subgraph "Command Side - Write Operations"
        C1[REST API<br/>POST /orders]:::command
        C2[Command Handler<br/>Validation]:::command
        C3[Event Store<br/>DynamoDB]:::command
        C4[Append Event<br/>Immutable Log]:::command
    end

    subgraph "Event Bus"
        EB1[EventBridge<br/>Central Event Router]:::eventbus
        EB2[Event Rule 1<br/>Update Read Models]:::eventbus
        EB3[Event Rule 2<br/>Send Notification]:::eventbus
        EB4[Event Rule 3<br/>Trigger Workflow]:::eventbus
    end

    subgraph "Query Side - Read Operations"
        Q1[Read Model 1<br/>ElastiCache Redis]:::query
        Q2[Read Model 2<br/>Redshift OLAP]:::query
        Q3[Read Model 3<br/>Elasticsearch]:::query
        Q4[GraphQL API<br/>GET /orders/:id]:::query
    end

    subgraph "Event Projections"
        P1[Projection: Order Summary<br/>Lambda Function]:::projection
        P2[Projection: Sales Analytics<br/>Glue Job]:::projection
        P3[Projection: Search Index<br/>Lambda Function]:::projection
    end

    %% Command Flow
    C1 --> C2
    C2 --> C3
    C3 --> C4
    C4 --> EB1

    %% Event Routing
    EB1 --> EB2
    EB1 --> EB3
    EB1 --> EB4

    %% Projection Updates
    EB2 --> P1
    EB2 --> P2
    EB2 --> P3

    %% Read Model Updates
    P1 --> Q1
    P2 --> Q2
    P3 --> Q3

    %% Query Flow
    Q1 --> Q4
    Q2 --> Q4
    Q3 --> Q4

    %% Event Replay
    C3 -.->|"Replay events<br/>rebuild projections"| P1
    C3 -.->|"Temporal queries<br/>state at time T"| P2

    %% Consistency
    C4 -.->|"Strong consistency<br/>source of truth"| C3
    Q1 -.->|"Eventual consistency<br/>minutes delay"| EB1

    %% Styling
    classDef command fill:#E74C3C,stroke:#C0392B,stroke-width:3px,color:#fff
    classDef eventbus fill:#9B59B6,stroke:#8E44AD,stroke-width:3px,color:#fff
    classDef query fill:#3498DB,stroke:#2980B9,stroke-width:3px,color:#fff
    classDef projection fill:#2ECC71,stroke:#27AE60,stroke-width:3px,color:#fff

    %% Benefits
    subgraph "CQRS Benefits"
        B1[✅ Scale reads/writes<br/>independently]:::benefit
        B2[✅ Multiple read models<br/>optimized queries]:::benefit
        B3[✅ Audit trail<br/>full event history]:::benefit
        B4[✅ Time travel<br/>replay to any state]:::benefit
    end

    classDef benefit fill:#F39C12,stroke:#E67E22,stroke-width:2px,color:#fff

    %% Example Events
    subgraph "Sample Events"
        E1[OrderPlaced<br/>v1 @ 10:00]:::event
        E2[PaymentProcessed<br/>v2 @ 10:01]:::event
        E3[OrderShipped<br/>v3 @ 10:30]:::event
        E4[OrderDelivered<br/>v4 @ 12:00]:::event
    end

    classDef event fill:#1ABC9C,stroke:#16A085,stroke-width:2px,color:#fff

    E1 --> E2 --> E3 --> E4
    E4 -.-> C3
