    %% CAP Theorem
    subgraph "CAP Theorem Trade-offs"
        CAP1[PostgreSQL: CA<br/>Consistency + Availability]:::cap
        CAP2[DynamoDB: AP<br/>Availability + Partition tolerance]:::cap
        CAP3[Redis: CP<br/>Consistency + Partition tolerance]:::cap
    end

    classDef cap fill:#34495E,stroke:#2C3E50,stroke-width:2px,color:#fff

