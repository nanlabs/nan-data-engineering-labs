graph TB
    %% Polyglot Persistence - Multiple Database Types for Different Needs

    subgraph "Application Layer"
        APP1[Order Service<br/>Spring Boot]:::app
        APP2[User Service<br/>Node.js]:::app
        APP3[Analytics Service<br/>Python]:::app
        APP4[Search Service<br/>Elasticsearch API]:::app
    end

    subgraph "Event Store - DynamoDB"
        ES1[Event Log<br/>Append-only]:::dynamo
        ES2[Partition Key: aggregate_id<br/>Sort Key: version]:::dynamo
        ES3[Characteristics:<br/>• Single-digit ms latency<br/>• Unlimited scale<br/>• Pay per request]:::dynamo
        ES4[Use Cases:<br/>• Event sourcing<br/>• Session store<br/>• Shopping cart]:::dynamo
    end

    subgraph "Operational Database - PostgreSQL"
        PG1[Relational Tables<br/>ACID Transactions]:::postgres
        PG2[Users, Products, Orders<br/>Foreign Keys]:::postgres
        PG3[Characteristics:<br/>• Strong consistency<br/>• Complex joins<br/>• ACID guarantees]:::postgres
        PG4[Use Cases:<br/>• Transactional data<br/>• Business logic<br/>• Referential integrity]:::postgres
    end

    subgraph "Cache Layer - ElastiCache Redis"
        RC1[In-Memory KV Store<br/>Sub-millisecond]:::redis
        RC2[Read Models<br/>Materialized Views]:::redis
        RC3[Characteristics:<br/>• Ultra-fast reads<br/>• TTL expiration<br/>• Pub/Sub messaging]:::redis
        RC4[Use Cases:<br/>• Session cache<br/>• Real-time leaderboards<br/>• API rate limiting]:::redis
    end

    subgraph "Analytics Warehouse - Redshift"
        RS1[Columnar Storage<br/>Massively Parallel]:::redshift
        RS2[Star Schema<br/>Fact + Dimension Tables]:::redshift
        RS3[Characteristics:<br/>• Petabyte scale<br/>• Complex aggregations<br/>• SQL-based]:::redshift
        RS4[Use Cases:<br/>• Business intelligence<br/>• Historical analysis<br/>• Data science queries]:::redshift
    end

    subgraph "Search Index - Elasticsearch"
        EL1[Inverted Index<br/>Full-Text Search]:::elastic
        EL2[Product Catalog<br/>Fuzzy Matching]:::elastic
        EL3[Characteristics:<br/>• Fast text search<br/>• Faceted navigation<br/>• Relevance scoring]:::elastic
        EL4[Use Cases:<br/>• Product search<br/>• Log analytics<br/>• Autocomplete]:::elastic
    end

    subgraph "Data Lake - S3"
        S31[Object Storage<br/>Raw + Processed]:::s3
        S32[Parquet + Avro<br/>Columnar Formats]:::s3
        S33[Characteristics:<br/>• Unlimited scale<br/>• Low cost ($0.023/GB)<br/>• Athena queries]:::s3
        S34[Use Cases:<br/>• Long-term storage<br/>• ML datasets<br/>• Compliance archives]:::s3
    end

    %% Application Connections
    APP1 --> ES1
    APP1 --> PG1
    APP1 --> RC1

    APP2 --> PG1
    APP2 --> RC1

    APP3 --> RS1
    APP3 --> S31

    APP4 --> EL1

    %% Data Flow
    ES1 -.->|"Stream CDC<br/>Kinesis"| RC1
    ES1 -.->|"Batch ETL<br/>Glue"| RS1

    PG1 -.->|"Real-time<br/>Debezium"| RC1
    PG1 -.->|"Daily export<br/>S3"| S31

    S31 -.->|"Glue ETL<br/>Transform"| RS1
    S31 -.->|"Athena queries<br/>Ad-hoc"| RS1

    RC1 -.->|"Search indexing<br/>Logstash"| EL1

