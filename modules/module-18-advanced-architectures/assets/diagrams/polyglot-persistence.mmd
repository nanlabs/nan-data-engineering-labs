    %% Database Selection Guide
    subgraph "Database Selection Guide"
        G1[Transaction? → PostgreSQL<br/>Simple KV? → DynamoDB<br/>Cache? → Redis<br/>Search? → Elasticsearch<br/>Analytics? → Redshift<br/>Archive? → S3]:::guide
    end

