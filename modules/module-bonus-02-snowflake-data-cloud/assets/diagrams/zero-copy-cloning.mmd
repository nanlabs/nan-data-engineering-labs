    subgraph MonitoringQueries["📊 MONITORING QUERIES"]
        style MonitoringQueries fill:#FFE5E5,stroke:#E74C3C,stroke-width:2px

        Query1["-- Find all clones in account
        SELECT
            table_catalog || '.' || table_schema || '.' || table_name AS full_name,
            row_count,
            bytes / POW(1024, 3) AS size_gb,
            created
        FROM INFORMATION_SCHEMA.TABLES
        WHERE comment LIKE '%CLONE%'
           OR table_name LIKE '%_clone%'
        ORDER BY bytes DESC;"]

        Query2["-- Storage cost breakdown by table
        SELECT
            table_name,
            active_bytes / POW(1024, 3) AS active_gb,
            time_travel_bytes / POW(1024, 3) AS time_travel_gb,
            failsafe_bytes / POW(1024, 3) AS failsafe_gb,
            (active_bytes + time_travel_bytes + failsafe_bytes) / POW(1024, 3) AS total_gb
        FROM SNOWFLAKE.ACCOUNT_USAGE.TABLE_STORAGE_METRICS
        WHERE table_name LIKE '%clone%'
        ORDER BY total_gb DESC;"]

        Query3["-- Identify clone divergence
        WITH base_tables AS (
            SELECT table_name, bytes AS base_bytes
            FROM INFORMATION_SCHEMA.TABLES
            WHERE table_name NOT LIKE '%clone%'
        ),
        clone_tables AS (
            SELECT table_name, bytes AS clone_bytes
            FROM INFORMATION_SCHEMA.TABLES
            WHERE table_name LIKE '%clone%'
        )
        SELECT
            c.table_name,
            b.base_bytes / POW(1024, 3) AS original_gb,
            c.clone_bytes / POW(1024, 3) AS clone_gb,
            (c.clone_bytes - b.base_bytes) / POW(1024, 3) AS divergence_gb,
            ROUND((c.clone_bytes - b.base_bytes) * 100.0 / b.base_bytes, 2) AS divergence_pct
        FROM clone_tables c
        JOIN base_tables b ON REPLACE(c.table_name, '_clone', '') = b.table_name;"]
    end

