        SELECT * FROM orders_bronze_stream;"]

        Setup3["-- Step 3: Create silver table
        CREATE TABLE silver_orders (
            order_id INT PRIMARY KEY,
            customer_id INT,
            amount DECIMAL(10,2),
            status VARCHAR(50),
            order_date DATE,
            created_at TIMESTAMP,
            updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP()
        );"]

        Setup4["-- Step 4: Create Task 1 (bronze → silver)
        CREATE TASK process_bronze_to_silver
          WAREHOUSE = etl_wh
          SCHEDULE = '5 MINUTE'
          WHEN SYSTEM$STREAM_HAS_DATA('orders_bronze_stream')
        AS
          MERGE INTO silver_orders AS target
          USING (
              SELECT DISTINCT
                  order_id::INT AS order_id,
                  customer_id::INT AS customer_id,
                  amount::DECIMAL(10,2) AS amount,
                  status,
                  TO_DATE(created_at) AS order_date,
                  TO_TIMESTAMP(created_at) AS created_at,
                  METADATA$ACTION AS dml_action
              FROM orders_bronze_stream
              QUALIFY ROW_NUMBER() OVER (
                  PARTITION BY order_id
                  ORDER BY updated_at DESC
              ) = 1
          ) AS source
          ON target.order_id = source.order_id
          WHEN MATCHED AND source.dml_action = 'DELETE' THEN DELETE
          WHEN MATCHED THEN UPDATE SET
              amount = source.amount,
              status = source.status,
              updated_at = CURRENT_TIMESTAMP()
          WHEN NOT MATCHED THEN INSERT
              (order_id, customer_id, amount, status, order_date, created_at, updated_at)
          VALUES
              (source.order_id, source.customer_id, source.amount,
               source.status, source.order_date, source.created_at, CURRENT_TIMESTAMP());

        -- Enable task
        ALTER TASK process_bronze_to_silver RESUME;"]

        Setup5["-- Step 5: Create silver stream
        CREATE STREAM orders_silver_stream
        ON TABLE silver_orders;"]

        Setup6["-- Step 6: Create gold table
        CREATE TABLE gold_daily_sales (
            sale_date DATE PRIMARY KEY,
            order_count INT,
            customer_count INT,
            total_revenue DECIMAL(12,2),
            avg_order_value DECIMAL(10,2),
            max_order_value DECIMAL(10,2),
            updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP()
        );"]

        Setup7["-- Step 7: Create Task 2 (silver → gold)
        CREATE TASK process_silver_to_gold
          WAREHOUSE = etl_wh
          AFTER process_bronze_to_silver  -- DAG dependency!
        AS
          MERGE INTO gold_daily_sales AS target
          USING (
              SELECT
                  order_date AS sale_date,
                  COUNT(DISTINCT order_id) AS order_count,
                  COUNT(DISTINCT customer_id) AS customer_count,
                  SUM(amount) AS total_revenue,
                  AVG(amount) AS avg_order_value,
                  MAX(amount) AS max_order_value
              FROM orders_silver_stream
              WHERE METADATA$ACTION = 'INSERT'
              GROUP BY order_date
          ) AS source
          ON target.sale_date = source.sale_date
          WHEN MATCHED THEN UPDATE SET
              order_count = target.order_count + source.order_count,
              customer_count = target.customer_count + source.customer_count,
              total_revenue = target.total_revenue + source.total_revenue,
              avg_order_value = (target.total_revenue + source.total_revenue) /
                               NULLIF(target.order_count + source.order_count, 0),
              max_order_value = GREATEST(target.max_order_value, source.max_order_value),
              updated_at = CURRENT_TIMESTAMP()
          WHEN NOT MATCHED THEN INSERT VALUES
              (source.sale_date, source.order_count, source.customer_count,
               source.total_revenue, source.avg_order_value, source.max_order_value,
               CURRENT_TIMESTAMP());

        -- Enable task (auto-runs after Task 1)
        ALTER TASK process_silver_to_gold RESUME;"]

