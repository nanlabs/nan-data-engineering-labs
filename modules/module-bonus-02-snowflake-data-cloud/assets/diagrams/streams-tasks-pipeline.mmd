        Task1Logic["Transformation Logic<br/>━━━━━━━━━━━━━━━━━━━━━━━━━━<br/>1. Read from stream (changed rows only)<br/>2. Data quality checks:<br/>   - Remove NULL order_ids<br/>   - Validate amount > 0<br/>   - Parse timestamps<br/>3. Data type conversions:<br/>   - amount: STRING → DECIMAL(10,2)<br/>   - created_at: STRING → TIMESTAMP<br/>4. Deduplication:<br/>   - Keep latest per order_id<br/>5. Handle updates:<br/>   - DELETE old version<br/>   - INSERT new version"]

        Task1SQL["SQL Implementation<br/>━━━━━━━━━━━━━━━━━━━━━━━━━━<br/>MERGE INTO silver_orders AS target<br/>USING (<br/>  SELECT DISTINCT<br/>    order_id::INT AS order_id,<br/>    customer_id::INT AS customer_id,<br/>    amount::DECIMAL(10,2) AS amount,<br/>    status,<br/>    TO_TIMESTAMP(created_at) AS created_at,<br/>    METADATA$ACTION AS dml_action<br/>  FROM orders_bronze_stream<br/>  QUALIFY ROW_NUMBER() OVER (<br/>    PARTITION BY order_id<br/>    ORDER BY updated_at DESC<br/>  ) = 1<br/>) AS source<br/>ON target.order_id = source.order_id<br/>WHEN MATCHED AND source.dml_action = 'DELETE'<br/>  THEN DELETE<br/>WHEN MATCHED THEN UPDATE SET<br/>  amount = source.amount,<br/>  status = source.status<br/>WHEN NOT MATCHED THEN INSERT VALUES<br/>  (source.order_id, source.customer_id, ...);<br/><br/>Execution: Every 5 min if stream has data"]

        Task1Def --> Task1Logic
        Task1Logic --> Task1SQL
    end

