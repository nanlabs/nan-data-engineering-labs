        Task2Logic["Aggregation Logic<br/>━━━━━━━━━━━━━━━━━━━━━━━━━━<br/>1. Read from silver stream<br/>2. Calculate daily KPIs:<br/>   - Total revenue<br/>   - Order count<br/>   - Avg order value<br/>   - Customer count<br/>3. Group by date + dimensions<br/>4. MERGE into gold (upsert)<br/>5. Handle late-arriving data"]

        Task2SQL["SQL Implementation<br/>━━━━━━━━━━━━━━━━━━━━━━━━━━<br/>MERGE INTO gold_daily_sales AS target<br/>USING (<br/>  SELECT<br/>    DATE(order_date) AS sale_date,<br/>    COUNT(DISTINCT order_id) AS order_count,<br/>    COUNT(DISTINCT customer_id) AS customer_count,<br/>    SUM(amount) AS total_revenue,<br/>    AVG(amount) AS avg_order_value,<br/>    MAX(amount) AS max_order_value<br/>  FROM orders_silver_stream<br/>  WHERE METADATA$ACTION = 'INSERT'<br/>  GROUP BY DATE(order_date)<br/>) AS source<br/>ON target.sale_date = source.sale_date<br/>WHEN MATCHED THEN UPDATE SET<br/>  order_count = target.order_count + source.order_count,<br/>  total_revenue = target.total_revenue + source.total_revenue<br/>WHEN NOT MATCHED THEN INSERT VALUES<br/>  (source.sale_date, source.order_count, ...);<br/><br/>Execution: After Task 1 completes (DAG)"]

