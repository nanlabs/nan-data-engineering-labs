    "arn:aws:s3:::cloudmart-landing/*"
  ]
},
{
  "Effect": "Allow",
  "Action": [
    "s3:PutObject",
    "s3:PutObjectAcl"
  ],
  "Resource": [
    "arn:aws:s3:::cloudmart-bronze/*",
    "arn:aws:s3:::cloudmart-errors/*"
  ]
