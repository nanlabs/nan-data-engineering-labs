            BuildDimCustomer["👥 dim_customers<br/>════════════════<br/>Source: silver_customers<br/><br/>SCD Type 2: Full history<br/>Surrogate Key: customer_key<br/>Natural Key: customer_id<br/><br/>Attributes:<br/>├─ Customer info<br/>├─ Demographics<br/>├─ Segmentation<br/>└─ Effective dates"]

            BuildDimProduct["📦 dim_products<br/>════════════════<br/>Source: silver_products<br/><br/>SCD Type 2: Full history<br/>Surrogate Key: product_key<br/>Natural Key: product_id<br/><br/>Attributes:<br/>├─ Product details<br/>├─ Category hierarchy<br/>├─ Pricing tiers<br/>└─ Effective dates"]

            BuildDimDate["📅 dim_date<br/>════════════════<br/>Source: Generated<br/><br/>SCD Type 0: Static<br/>Natural Key: date<br/><br/>Attributes:<br/>├─ Date components<br/>├─ Fiscal calendar<br/>├─ Holidays<br/>└─ Business days"]
        end

