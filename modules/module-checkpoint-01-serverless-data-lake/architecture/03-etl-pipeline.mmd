    subgraph OrchestrationLayer["🎼 ORCHESTRATION & SCHEDULING"]
        direction TB

        GlueWorkflow["AWS Glue Workflow<br/>════════════════════<br/>Workflow: cloudmart-etl-pipeline<br/><br/>Triggers:<br/>├─ Scheduled (Daily 2 AM UTC)<br/>├─ On-Demand (Manual)<br/>└─ Event-Driven (S3 notification)<br/><br/>Execution Mode:<br/>  • Sequential within stage<br/>  • Parallel across data sources<br/>  • Retry on failure (3 attempts)"]

        JobDependencies["Job Dependencies<br/>═══════════════════<br/>Stage 1: Bronze → Silver<br/>  ├─ transactions_cleaning<br/>  ├─ customers_cleaning<br/>  ├─ products_cleaning<br/>  └─ web_events_cleaning<br/>  (Run in parallel)<br/><br/>Stage 2: Silver → Gold<br/>  ├─ build_dimensions<br/>  │   (Wait for all Stage 1)<br/>  ├─ build_fact_sales<br/>  │   (Wait for dimensions)<br/>  └─ build_aggregations<br/>      (Wait for fact tables)"]

        EventBridge["Amazon EventBridge<br/>═════════════════════<br/>Rules:<br/>├─ Daily schedule (cron)<br/>├─ S3 object created<br/>├─ Glue job state change<br/>└─ CloudWatch alarms<br/><br/>Targets:<br/>├─ Start Glue Workflow<br/>├─ Send SNS notification<br/>├─ Update DynamoDB<br/>└─ Invoke Lambda"]

