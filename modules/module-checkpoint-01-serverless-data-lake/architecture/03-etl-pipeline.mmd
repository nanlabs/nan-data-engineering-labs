        subgraph AggregationsJob["ETL Job: build_aggregations"]
            direction TB

            AggConfig["⚙️ Job Configuration<br/>═════════════════════<br/>Worker Type: G.2X<br/>Number of Workers: 3 DPUs<br/>Timeout: 60 minutes"]

            DailySales["📊 agg_daily_sales<br/>═══════════════════════<br/>Granularity: Day<br/><br/>GROUP BY:<br/>  date, product_id, customer_segment<br/><br/>Metrics:<br/>├─ total_revenue<br/>├─ total_profit<br/>├─ total_quantity<br/>├─ avg_order_value<br/>├─ order_count<br/>├─ unique_customers<br/>└─ margin_percent"]

            CustomerMetrics["👤 agg_customer_metrics<br/>══════════════════════════<br/>Granularity: Customer + Month<br/><br/>Metrics:<br/>├─ total_spend<br/>├─ order_count<br/>├─ avg_order_value<br/>├─ first_purchase_date<br/>├─ last_purchase_date<br/>├─ recency_days<br/>├─ frequency<br/>├─ monetary<br/>├─ rfm_score<br/>└─ customer_lifetime_value"]

