            FactConfig["⚙️ Job Configuration<br/>═════════════════════<br/>Worker Type: G.2X<br/>Number of Workers: 5 DPUs<br/>Timeout: 90 minutes<br/>Bookmark: Enabled<br/>(Complex joins & aggregations)"]

            FactJoin["🔗 Join Operations<br/>═══════════════════<br/>Main table: silver_transactions<br/><br/>LEFT JOIN silver_customers<br/>  ON txn.customer_id = cust.customer_id<br/>  AND cust.is_current = true<br/><br/>LEFT JOIN silver_products<br/>  ON txn.product_id = prod.product_id<br/>  AND prod.is_current = true<br/><br/>INNER JOIN dim_date<br/>  ON txn.transaction_date = date.date<br/><br/>Broadcast Hints:<br/>  • dim_date (small dimension)<br/>  • Optimize shuffle partitions"]

            FactTransform["🎯 Business Logic<br/>════════════════════<br/>Calculate metrics:<br/>├─ revenue = quantity * unit_price<br/>├─ cost = quantity * unit_cost<br/>├─ profit = revenue - cost<br/>├─ margin = profit / revenue<br/>├─ discount_amount<br/>├─ net_revenue<br/>└─ tax_amount<br/><br/>Dimension keys:<br/>├─ date_key (FK)<br/>├─ customer_key (FK)<br/>├─ product_key (FK)<br/>└─ surrogate keys from dimensions"]

            FactWrite["💾 Write Fact Table<br/>═════════════════════<br/>Target: gold_fact_sales<br/>Format: Parquet + Snappy<br/>Partitioning: year/month<br/>Clustering: customer_id<br/>Optimize: Z-order(transaction_date)<br/><br/>Statistics: Full"]
        end

