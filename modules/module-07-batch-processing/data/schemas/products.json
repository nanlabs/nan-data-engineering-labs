{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Product",
  "description": "Product catalog for batch processing exercises",
  "type": "object",
  "required": ["product_id", "name", "category", "price"],
  "properties": {
    "product_id": {
      "type": "string",
      "description": "Unique product identifier",
      "pattern": "^PROD[0-9]{5}$",
      "examples": ["PROD00001"]
    },
    "name": {
      "type": "string",
      "description": "Product name",
      "minLength": 3,
      "maxLength": 200
    },
    "category": {
      "type": "string",
      "description": "Product category",
      "enum": ["electronics", "clothing", "books", "home", "sports", "toys", "food", "beauty"]
    },
    "price": {
      "type": "number",
      "description": "Product price in USD",
      "minimum": 0.01,
      "maximum": 50000.00
    },
    "stock": {
      "type": "integer",
      "description": "Current stock quantity",
      "minimum": 0,
      "maximum": 100000
    },
    "brand": {
      "type": "string",
      "description": "Product brand",
      "maxLength": 100
    },
    "rating": {
      "type": "number",
      "description": "Average product rating",
      "minimum": 0.0,
      "maximum": 5.0
    },
    "reviews_count": {
      "type": "integer",
      "description": "Number of reviews",
      "minimum": 0
    },
    "is_available": {
      "type": "boolean",
      "description": "Whether product is available for purchase"
    }
  }
}
