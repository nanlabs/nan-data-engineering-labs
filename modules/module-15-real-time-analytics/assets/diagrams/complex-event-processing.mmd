    subgraph "Pattern Examples"
        EX1["1. Account Takeover<br/>Login(new_device) → PasswordChange → EmailChange<br/>WITHIN 5 MINUTES"]:::example

        EX2["2. Impossible Travel<br/>Login(NY, 10:00) → Login(LA, 10:30)<br/>DISTANCE > 3000 miles in 30 min"]:::example

        EX3["3. Velocity Check<br/>Purchase → Purchase → Purchase<br/>3 purchases WITHIN 1 MINUTE"]:::example

        EX4["4. Abandonment<br/>AddToCart → ViewCart → (NO Checkout)<br/>WITHIN 1 HOUR → Send reminder"]:::example
    end

    CEP4 --> EX1
    CEP4 --> EX2
    CEP4 --> EX3
    CEP4 --> EX4

    subgraph "Flink SQL - MATCH_RECOGNIZE"
        SQL["SELECT *<br/>FROM transactions<br/>MATCH_RECOGNIZE (<br/>  PARTITION BY user_id<br/>  ORDER BY event_time<br/>  MEASURES<br/>    A.event_time AS login_time,<br/>    C.event_time AS purchase_time,<br/>    C.amount AS purchase_amount<br/>  ONE ROW PER MATCH<br/>  AFTER MATCH SKIP TO NEXT ROW<br/>  PATTERN (A B* C)<br/>  WITHIN INTERVAL '10' MINUTE<br/>  DEFINE<br/>    A AS A.event_type = 'login',<br/>    B AS B.event_type IN ('view_product', 'add_to_cart'),<br/>    C AS C.event_type = 'purchase' AND C.amount > 1000<br/>)"]:::sql
    end

    EX1 --> SQL

