    end

    E1 --> E2 --> E3 --> E4 --> E5

    subgraph "CEP Pattern Definition"
        P1["PATTERN: Fraud Detection<br/>Login → HighValuePurchase → ShippingChange<br/>WITHIN 10 MINUTES"]:::pattern

