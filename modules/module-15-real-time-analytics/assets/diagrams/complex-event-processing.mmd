    %% CEP Operators
    subgraph "CEP Operators"
        OP["• next(): Strict contiguity (A → B)<br/>• followedBy(): Relaxed (A ... B)<br/>• followedByAny(): Non-deterministic<br/>• notNext(): Negative pattern (NOT B after A)<br/>• within(): Time constraint<br/>• times(): Repetition (A{3} = A A A)<br/>• oneOrMore(): A+ (at least once)<br/>• timesOrMore(): A{2,} (2 or more)"]:::operator
    end

    classDef operator fill:#1ABC9C,stroke:#16A085,stroke-width:2px,color:#fff,text-align:left

