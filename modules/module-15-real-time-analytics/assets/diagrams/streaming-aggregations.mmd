graph TB
    %% Streaming Aggregations - Real-Time Metrics

    subgraph "Event Stream"
        ES[Raw Events<br/>user_id, product_id, amount, timestamp]:::stream
    end

    subgraph "1. COUNT Aggregation"
        C1["SELECT<br/>  TUMBLE_START(ts, INTERVAL '1' MINUTE) as window_start,<br/>  COUNT(*) as event_count<br/>FROM events<br/>GROUP BY TUMBLE(ts, INTERVAL '1' MINUTE)"]:::sql

        C2[Result:<br/>10:00 → 1,523 events<br/>10:01 → 1,689 events<br/>10:02 → 1,445 events]:::result

        C3[Use Case: Live traffic monitoring]:::usecase
    end

    ES --> C1
    C1 --> C2
    C2 --> C3

    subgraph "2. SUM Aggregation"
        S1["SELECT<br/>  product_id,<br/>  SUM(amount) as total_revenue<br/>FROM transactions<br/>GROUP BY product_id,<br/>  TUMBLE(event_time, INTERVAL '5' MINUTE)"]:::sql

        S2[Result:<br/>PROD_123 → $12,450<br/>PROD_456 → $8,920<br/>PROD_789 → $15,670]:::result

        S3[Use Case: Real-time revenue dashboard]:::usecase
    end

    ES --> S1
    S1 --> S2
    S2 --> S3

    subgraph "3. AVG with Sliding Window"
        A1["SELECT<br/>  service_name,<br/>  AVG(response_time_ms) as avg_latency<br/>FROM metrics<br/>GROUP BY service_name,<br/>  HOP(ts, INTERVAL '1' MINUTE, INTERVAL '5' MINUTE)"]:::sql

        A2[Result:<br/>api-gateway → 45.2ms<br/>auth-service → 12.8ms<br/>payment-service → 89.5ms]:::result

        A3[Use Case: SLA monitoring]:::usecase
    end

    ES --> A1
    A1 --> A2
    A2 --> A3

    subgraph "4. Top-N Query"
        T1["SELECT *<br/>FROM (<br/>  SELECT product_id, SUM(quantity) as total_qty,<br/>    ROW_NUMBER() OVER (<br/>      PARTITION BY TUMBLE(ts, INTERVAL '1' HOUR)<br/>      ORDER BY SUM(quantity) DESC<br/>    ) as rank<br/>  FROM sales<br/>  GROUP BY product_id, TUMBLE(ts, INTERVAL '1' HOUR)<br/>)<br/>WHERE rank <= 10"]:::sql

        T2[Result (Top 10 Products):<br/>1. PROD_123 → 2,450 units<br/>2. PROD_456 → 1,980 units<br/>3. PROD_789 → 1,750 units<br/>...<br/>10. PROD_321 → 890 units]:::result

        T3[Use Case: Trending products]:::usecase
    end

    ES --> T1
    T1 --> T2
    T2 --> T3

    subgraph "5. DISTINCT Count"
        D1["SELECT<br/>  TUMBLE_START(ts, INTERVAL '1' MINUTE) as window,<br/>  COUNT(DISTINCT user_id) as unique_users<br/>FROM page_views<br/>GROUP BY TUMBLE(ts, INTERVAL '1' MINUTE)"]:::sql

        D2[Result:<br/>10:00 → 523 unique users<br/>10:01 → 587 unique users<br/>10:02 → 612 unique users]:::result

        D3[Use Case: DAU/MAU metrics]:::usecase
    end

    ES --> D1
    D1 --> D2
    D2 --> D3

    subgraph "6. Percentile Calculation"
        P1["SELECT<br/>  TUMBLE_START(ts, INTERVAL '5' MINUTE) as window,<br/>  service,<br/>  PERCENTILE_CONT(0.50) WITHIN GROUP (ORDER BY latency) as p50,<br/>  PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY latency) as p95,<br/>  PERCENTILE_CONT(0.99) WITHIN GROUP (ORDER BY latency) as p99<br/>FROM api_logs<br/>GROUP BY service, TUMBLE(ts, INTERVAL '5' MINUTE)"]:::sql

        P2[Result (API Service):<br/>p50: 25ms<br/>p95: 120ms<br/>p99: 450ms]:::result

        P3[Use Case: Performance monitoring]:::usecase
    end

    ES --> P1
    P1 --> P2
    P2 --> P3

