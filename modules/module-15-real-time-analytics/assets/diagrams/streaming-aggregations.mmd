    %% Advanced Patterns
    subgraph "Advanced Aggregation Patterns"
        ADV["Multi-dimensional rollup:<br/>SELECT region, product_category, SUM(revenue)<br/>FROM sales<br/>GROUP BY ROLLUP(region, product_category)<br/><br/>Deduplication:<br/>SELECT DISTINCT event_id, user_id, action<br/>FROM events MATCH_RECOGNIZE (<br/>  PARTITION BY event_id<br/>  ORDER BY ts<br/>  MEASURES FIRST(A.user_id) as user_id<br/>  PATTERN (A B*)<br/>)<br/><br/>Late data handling:<br/>WATERMARK FOR ts AS ts - INTERVAL '1' MINUTE"]:::advanced
    end

