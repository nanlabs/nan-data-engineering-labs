# ============================================================================
# Module 04: Python for Data Engineering - Environment Variables
# ============================================================================
# Copiar este archivo a .env y ajustar valores según necesidad
# Comando: cp .env.example .env
# ============================================================================

# ----------------------------------------------------------------------------
# Jupyter Lab Configuration
# ----------------------------------------------------------------------------

# Puerto para acceder a Jupyter Lab
JUPYTER_PORT=8888

# Token de autenticación para Jupyter Lab
# Cambiar en producción por seguridad
JUPYTER_TOKEN=python-data-2026

# Habilitar Jupyter Lab (vs Notebook clásico)
JUPYTER_ENABLE_LAB=yes

# ----------------------------------------------------------------------------
# PostgreSQL Configuration (OPCIONAL - descomentar si se usa)
# ----------------------------------------------------------------------------

# Puerto para PostgreSQL (usar diferente a 5432 si tienes otra instancia)
# POSTGRES_PORT=5433

# Nombre de la base de datos
# POSTGRES_DB=python_data

# Usuario de PostgreSQL
# POSTGRES_USER=python_user

# Contraseña de PostgreSQL
# POSTGRES_PASSWORD=python_pass

# Connection string completo (para usar en notebooks)
# DATABASE_URL=postgresql://python_user:python_pass@postgres:5432/python_data

# ----------------------------------------------------------------------------
# MinIO Configuration (OPCIONAL - descomentar si se usa)
# ----------------------------------------------------------------------------

# Puerto API de MinIO
# MINIO_API_PORT=9000

# Puerto Console de MinIO
# MINIO_CONSOLE_PORT=9001

# Credenciales de MinIO (S3-compatible)
# MINIO_ROOT_USER=minio_admin
# MINIO_ROOT_PASSWORD=minio_pass123

# Endpoint para boto3/s3fs
# MINIO_ENDPOINT=http://minio:9000

# ----------------------------------------------------------------------------
# Python Environment
# ----------------------------------------------------------------------------

# Unbuffered output (mejor para logs)
PYTHONUNBUFFERED=1

# No crear archivos .pyc
PYTHONDONTWRITEBYTECODE=1

# Nivel de log de Python
# Opciones: DEBUG, INFO, WARNING, ERROR, CRITICAL
PYTHON_LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Timezone
# ----------------------------------------------------------------------------

# Zona horaria del container
TZ=America/Santiago

# Otras opciones comunes:
# TZ=America/Mexico_City
# TZ=America/Lima
# TZ=America/Bogota
# TZ=America/Buenos_Aires
# TZ=UTC

# ----------------------------------------------------------------------------
# Data Paths (dentro del container)
# ----------------------------------------------------------------------------

# Path a datos raw
DATA_RAW_PATH=/home/jovyan/work/data/raw

# Path a datos procesados
DATA_PROCESSED_PATH=/home/jovyan/work/data/processed

# Path a schemas
DATA_SCHEMA_PATH=/home/jovyan/work/data/schemas

# ----------------------------------------------------------------------------
# API Keys & Secrets (para ejercicios)
# ----------------------------------------------------------------------------

# API Keys de ejemplo (reemplazar con tus propias keys si las usas)
# EXAMPLE_API_KEY=your_api_key_here
# EXAMPLE_API_SECRET=your_api_secret_here

# ----------------------------------------------------------------------------
# AWS Configuration (OPCIONAL - para ejercicios con S3)
# ----------------------------------------------------------------------------

# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_DEFAULT_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# ----------------------------------------------------------------------------
# Resource Limits
# ----------------------------------------------------------------------------

# Límites de CPU (número de cores)
JUPYTER_CPU_LIMIT=2.0
JUPYTER_CPU_RESERVATION=0.5

# Límites de memoria
JUPYTER_MEMORY_LIMIT=4G
JUPYTER_MEMORY_RESERVATION=1G

# ----------------------------------------------------------------------------
# Development Settings
# ----------------------------------------------------------------------------

# Modo debug (más logs)
DEBUG=false

# Recargar automáticamente módulos en Jupyter
AUTORELOAD=true

# Mostrar warnings de deprecación
PYTHONWARNINGS=default

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------

# Formato de logs
LOG_FORMAT=json

# Path para guardar logs
LOG_PATH=/home/jovyan/work/logs

# Nivel de logs para diferentes componentes
LOG_LEVEL_JUPYTER=INFO
LOG_LEVEL_SQLALCHEMY=WARNING
LOG_LEVEL_URLLIB3=WARNING

# ----------------------------------------------------------------------------
# Notas
# ----------------------------------------------------------------------------
#
# 1. NO COMMITEAR el archivo .env al repositorio (está en .gitignore)
# 2. Para producción, usar secrets managers (AWS Secrets Manager, etc.)
# 3. Cambiar todos los passwords por valores seguros
# 4. Documentar cualquier variable adicional que agregues
#
# ============================================================================
