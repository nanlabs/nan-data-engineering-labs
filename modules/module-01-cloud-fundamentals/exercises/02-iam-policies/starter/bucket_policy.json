{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyDeleteForNonAdmins",
      "Effect": "Deny",
      "Principal": "*",
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteObjectVersion"
      ],
      "Resource": "arn:aws:s3:::my-data-lake-raw/*",
      "Condition": {
        "StringNotEquals": {
          "aws:username": ["admin-user"]
        }
      }
    },
    {
      "Sid": "RequireEncryptionOnUpload",
      "Effect": "Deny",
      "Principal": "*",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::my-data-lake-raw/*",
      "Condition": {
        "StringNotEquals": {
          "s3:x-amz-server-side-encryption": "AES256"
        }
      }
    },
    {
      "Sid": "AllowCrossAccountRead",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::999999999999:root"
      },
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::my-data-lake-raw",
        "arn:aws:s3:::my-data-lake-raw/partner-reports/*"
      ]
    }
  ]
}
