# ============================================================================
# TERRAFORM VARIABLES - EXAMPLE VALUES
# ============================================================================
# Copy this file to terraform.tfvars and update with your actual values
# DO NOT commit terraform.tfvars to version control (add to .gitignore)
# ============================================================================

# ============================================================================
# PROJECT CONFIGURATION
# ============================================================================

# Name of the project (used as prefix for all resources)
# Must be lowercase alphanumeric with hyphens, max 20 characters
project_name = "rideshare-analytics"

# Environment name: dev, staging, or prod
# Different environments should use different AWS accounts or regions
environment = "dev"

# AWS region for resource deployment
# Recommended: us-east-1, us-west-2, eu-west-1
aws_region = "us-east-1"

# ============================================================================
# KINESIS CONFIGURATION
# ============================================================================

# Number of shards per Kinesis stream
# Each shard provides 1 MB/s write and 2 MB/s read capacity
# Rides stream (high volume): 2 shards = 2 MB/s write
# Locations stream (very high): 2 shards = 2 MB/s write
# Payments stream (medium): 1 shard = 1 MB/s write
# Ratings stream (low): 1 shard = 1 MB/s write
kinesis_shard_count = 2

# Data retention period in hours (24-8760)
# 24 hours (1 day) - minimum, good for dev
# 168 hours (7 days) - recommended for prod
# 8760 hours (365 days) - maximum, for compliance
kinesis_retention_hours = 24

# Enable enhanced (shard-level) monitoring
# Provides detailed metrics per shard
# Additional cost: $0.015 per shard-hour
kinesis_enhanced_monitoring = true

# ============================================================================
# LAMBDA CONFIGURATION
# ============================================================================

# Memory allocation for Lambda functions (128-10240 MB)
# More memory = more CPU and network bandwidth
# Recommended: 512 MB for balanced performance/cost
# Note: Pricing is proportional to memory * execution time
lambda_memory_mb = 512

# Timeout for Lambda functions (1-900 seconds)
# Recommended: 60 seconds for stream processing
# Lower timeout = faster failure detection
lambda_timeout_seconds = 60

# Number of records to batch from Kinesis (1-10000)
# Higher batch = better throughput, higher latency
# Lower batch = lower latency, more invocations
# Recommended: 100 for balanced performance
lambda_batch_size = 100

# Concurrent batches per shard (1-10)
# Higher parallelization = higher throughput
# Can cause out-of-order processing
# Recommended: 10 for maximum throughput
lambda_parallelization_factor = 10

# Reserved concurrent executions per function
# Prevents function from consuming all account concurrency
# Account limit: 1000 concurrent executions
lambda_reserved_concurrency_rides = 100
lambda_reserved_concurrency_locations = 100
lambda_reserved_concurrency_payments = 50
lambda_reserved_concurrency_ratings = 20

# CloudWatch Logs retention (days)
# Options: 1, 3, 5, 7, 14, 30, 60, 90, 120, 150, 180, 365, 400, 545, 731, 1827, 3653
# Recommended: 7 for dev, 30 for prod
lambda_log_retention_days = 7

# ============================================================================
# DYNAMODB CONFIGURATION
# ============================================================================

# DynamoDB billing mode
# PAY_PER_REQUEST: No capacity planning, pay per request (recommended)
# PROVISIONED: Set RCU/WCU, cheaper for predictable workloads
dynamodb_billing_mode = "PAY_PER_REQUEST"

# Provisioned capacity (only used if billing_mode = PROVISIONED)
# Read Capacity Units: 1 RCU = 1 strongly consistent read/s (4 KB)
# Write Capacity Units: 1 WCU = 1 write/s (1 KB)
dynamodb_read_capacity = 5
dynamodb_write_capacity = 5

# Enable point-in-time recovery (PITR)
# Provides continuous backups for 35 days
# Additional cost: Backup storage charges
# Recommended: true for production
dynamodb_point_in_time_recovery = true

# Enable DynamoDB Streams for Change Data Capture
# Required for CDC patterns and event-driven architectures
# Recommended: true
dynamodb_stream_enabled = true

# Enable TTL for automatic item expiration
# No additional cost
# Recommended: true for time-series data
dynamodb_ttl_enabled = true

# TTL retention periods
# Rides: 7 days (recent rides in hot storage)
# Metrics: 30 days (recent metrics for dashboards)
rides_ttl_days = 7
metrics_ttl_days = 30

# ============================================================================
# KINESIS DATA ANALYTICS CONFIGURATION
# ============================================================================

# Kinesis Processing Units (KPU)
# Each KPU provides: 1 vCPU and 4 GB memory
# Minimum: 1 KPU per application
# Recommended: Start with 1, scale as needed
analytics_kpu = 1

# Parallelism for Flink applications
# Number of parallel tasks per application
# Recommended: 2 for fault tolerance
analytics_parallelism = 2

# Enable/disable analytics applications
# Enable only the applications you need to reduce costs
enable_surge_pricing_analytics = true
enable_realtime_metrics_analytics = true
enable_hot_spots_analytics = true

# ============================================================================
# S3 CONFIGURATION
# ============================================================================

# Enable versioning for S3 buckets
# Protects against accidental deletion
# Additional cost: Storage for all versions
# Recommended: true for production
s3_versioning_enabled = true

# Lifecycle policy: days before transitioning to Glacier
# Standard: $0.023/GB-month
# Glacier: $0.004/GB-month
# Savings: ~83%
# Recommended: 90 days for compliance
s3_lifecycle_glacier_days = 90

# Lifecycle policy: days before transitioning to Deep Archive
# Deep Archive: $0.00099/GB-month
# Savings: ~96% vs Standard
# Recommended: 365 days for long-term retention
s3_lifecycle_deep_archive_days = 365

# Enable S3 Intelligent-Tiering
# Automatically moves objects between access tiers
# Additional cost: $0.0025 per 1000 objects monitored
# Recommended: false for predictable access patterns
s3_intelligent_tiering_enabled = false

# ============================================================================
# MONITORING & ALERTING CONFIGURATION
# ============================================================================

# Email address for CloudWatch alarm notifications
# Leave empty to skip email notifications
# Example: "ops-team@example.com"
alert_email = ""

# Slack webhook URL for notifications
# Leave empty to skip Slack notifications
# Example: "https://hooks.slack.com/services/XXX/YYY/ZZZ"
alert_slack_webhook = ""

# CloudWatch Logs retention (days)
# Options: 1, 3, 5, 7, 14, 30, 60, 90, 120, 150, 180, 365, 400, 545, 731, 1827, 3653
# Recommended: 7 for dev, 30 for prod
cloudwatch_log_retention_days = 7

# Enable AWS X-Ray distributed tracing
# Helps identify performance bottlenecks
# Additional cost: $5 per 1M traces + $0.50 per 1M retrievals
# Recommended: true for debugging
enable_xray_tracing = true

# Enable detailed CloudWatch monitoring
# Provides 1-minute metrics instead of 5-minute
# Additional cost: $0.30 per metric per month
# Recommended: true for production
enable_detailed_monitoring = true

# Lambda error rate threshold (percentage)
# Triggers alarm when error rate exceeds threshold
# Recommended: 5% for production
lambda_error_rate_threshold_percent = 5

# Kinesis iterator age threshold (seconds)
# Triggers alarm when processing falls behind
# Recommended: 60 seconds
kinesis_iterator_age_threshold_seconds = 60

# DLQ message threshold
# Triggers alarm when DLQ has messages
# Recommended: 10 for immediate attention
dlq_message_threshold = 10

# ============================================================================
# STEP FUNCTIONS CONFIGURATION
# ============================================================================

# Enable daily aggregation workflow
# Runs batch ETL jobs for historical data
# Recommended: true for production
enable_daily_aggregation = true

# Daily aggregation schedule (cron expression in UTC)
# Default: Daily at midnight UTC (0 0 * * ? *)
# Format: cron(minutes hours day-of-month month day-of-week year)
daily_aggregation_schedule = "cron(0 0 * * ? *)"

# Enable weekly reporting workflow
# Generates weekly summary reports
# Recommended: true for business insights
enable_weekly_reporting = true

# Weekly reporting schedule (cron expression in UTC)
# Default: Weekly on Sunday at midnight UTC (0 0 ? * SUN *)
# Format: cron(minutes hours day-of-month month day-of-week year)
weekly_reporting_schedule = "cron(0 0 ? * SUN *)"

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Enable automatic KMS key rotation
# Rotates keys annually
# No additional cost
# Recommended: true for security best practices
kms_key_rotation_enabled = true

# KMS key deletion window (7-30 days)
# Waiting period before key deletion
# Recommended: 30 days for production (max recovery time)
kms_key_deletion_window_days = 30

# Enable VPC endpoints for AWS services
# Reduces data transfer costs and improves security
# Additional cost: $0.01 per hour per endpoint + data charges
# Requires VPC configuration
# Recommended: true for production with VPC
enable_vpc_endpoints = false

# VPC ID (required if enable_vpc_endpoints = true)
# Example: "vpc-0123456789abcdef0"
vpc_id = ""

# Private subnet IDs (required if enable_vpc_endpoints = true)
# Example: ["subnet-0123456789abcdef0", "subnet-0123456789abcdef1"]
private_subnet_ids = []

# ============================================================================
# COST OPTIMIZATION CONFIGURATION
# ============================================================================

# Enable cost allocation tags
# Helps track costs per resource
# No additional cost
# Recommended: true
enable_cost_allocation_tags = true

# Cost center identifier for billing
# Used for internal cost tracking
# Example: "engineering", "data-platform", "analytics"
cost_center = "engineering"

# Owner or team responsible for infrastructure
# Used for accountability and contact
# Example: "data-platform-team", "devops-team"
owner = "data-platform-team"

# ============================================================================
# ADDITIONAL TAGS
# ============================================================================

# Additional tags to apply to all resources
# Key-value pairs for resource organization
tags = {
  Terraform   = "true"
  Application = "real-time-analytics"
  Repository  = "training-cloud-data"
  Module      = "checkpoint-02"
  Contact     = "data-team@example.com"
  CostCenter  = "engineering"
  Compliance  = "none"
}

# ============================================================================
# EXAMPLE CONFIGURATIONS FOR DIFFERENT ENVIRONMENTS
# ============================================================================

