      "DataSource": {
        "Type": "ATHENA",
        "Arn": "arn:aws:quicksight:${AWS_REGION}:${AWS_ACCOUNT_ID}:datasource/sales-analytics-athena",
        "ConnectionProperties": {
          "Database": "ride_analytics",
          "Catalog": "AwsDataCatalog",
          "WorkGroup": "primary"
        }
      },
      "ImportMode": "SPICE",
      "RefreshSchedule": {
        "ScheduleId": "sales-analytics-refresh",
        "ScheduleFrequency": {
          "Interval": "HOURLY",
          "TimeOfTheDay": "00:00",
          "RefreshType": "FULL_REFRESH"
        },
        "ScheduleArn": "arn:aws:quicksight:${AWS_REGION}:${AWS_ACCOUNT_ID}:dataset/sales-analytics-athena/refresh-schedule/sales-analytics-refresh",
        "StartAfterDateTime": "2026-03-09T00:00:00Z"
      },
      "CustomSql": {
        "DataSourceArn": "arn:aws:quicksight:${AWS_REGION}:${AWS_ACCOUNT_ID}:datasource/sales-analytics-athena",
        "Name": "SalesAnalyticsQuery",
        "SqlQuery": "SELECT date_trunc('hour', timestamp) as hour, city, status, COUNT(*) as ride_count, SUM(fare) as revenue, AVG(fare) as avg_fare, AVG(rating) as avg_rating, AVG(duration) as avg_duration FROM rides WHERE timestamp >= date_add('day', -30, current_timestamp) GROUP BY date_trunc('hour', timestamp), city, status ORDER BY hour DESC"
      },
      "Columns": [
        {
          "Name": "hour",
          "Type": "DATETIME"
        },
        {
          "Name": "city",
          "Type": "STRING"
        },
        {
          "Name": "status",
          "Type": "STRING"
        },
        {
          "Name": "ride_count",
          "Type": "INTEGER"
        },
        {
          "Name": "revenue",
          "Type": "DECIMAL"
        },
        {
          "Name": "avg_fare",
          "Type": "DECIMAL"
        },
        {
          "Name": "avg_rating",
          "Type": "DECIMAL"
        },
        {
          "Name": "avg_duration",
          "Type": "DECIMAL"
        }
      ]
    }
