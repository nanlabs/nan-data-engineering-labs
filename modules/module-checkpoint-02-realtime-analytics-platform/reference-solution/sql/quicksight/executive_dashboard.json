      "DataSetPlaceholder": "ExecutiveMetricsDataSet",
      "DataSetArn": "arn:aws:quicksight:${AWS_REGION}:${AWS_ACCOUNT_ID}:dataset/executive-metrics",
      "DataSource": {
        "Type": "ATHENA",
        "Arn": "arn:aws:quicksight:${AWS_REGION}:${AWS_ACCOUNT_ID}:datasource/executive-athena",
        "ConnectionProperties": {
          "Database": "ride_analytics",
          "Catalog": "AwsDataCatalog",
          "WorkGroup": "primary"
        }
      },
      "ImportMode": "SPICE",
      "RefreshSchedule": {
        "ScheduleId": "executive-daily-refresh",
        "ScheduleFrequency": {
          "Interval": "DAILY",
          "TimeOfTheDay": "06:00",
          "RefreshType": "FULL_REFRESH"
        },
        "ScheduleArn": "arn:aws:quicksight:${AWS_REGION}:${AWS_ACCOUNT_ID}:dataset/executive-metrics/refresh-schedule/daily",
        "StartAfterDateTime": "2026-03-09T06:00:00Z"
      },
      "CustomSql": {
        "DataSourceArn": "arn:aws:quicksight:${AWS_REGION}:${AWS_ACCOUNT_ID}:datasource/executive-athena",
        "Name": "ExecutiveMetricsQuery",
        "SqlQuery": "WITH daily_metrics AS (SELECT date_trunc('day', timestamp) as day, city, COUNT(DISTINCT passenger_id) as active_users, COUNT(*) as total_rides, SUM(fare) as revenue, AVG(rating) as avg_rating, COUNT(DISTINCT CASE WHEN status = 'completed' THEN ride_id END) as completed_rides, COUNT(DISTINCT CASE WHEN status = 'cancelled' THEN ride_id END) as cancelled_rides FROM rides WHERE timestamp >= date_add('month', -6, current_timestamp) GROUP BY date_trunc('day', timestamp), city), user_retention AS (SELECT day, city, COUNT(DISTINCT passenger_id) as returning_users FROM rides r1 WHERE EXISTS (SELECT 1 FROM rides r2 WHERE r2.passenger_id = r1.passenger_id AND date_trunc('day', r2.timestamp) < date_trunc('day', r1.timestamp) AND r2.timestamp >= date_add('month', -6, current_timestamp)) AND timestamp >= date_add('month', -6, current_timestamp) GROUP BY date_trunc('day', timestamp), city) SELECT dm.day, dm.city, dm.active_users, dm.total_rides, dm.revenue, dm.avg_rating, dm.completed_rides, dm.cancelled_rides, COALESCE(ur.returning_users, 0) as returning_users, CAST(COALESCE(ur.returning_users, 0) AS DOUBLE) / NULLIF(dm.active_users, 0) as retention_rate FROM daily_metrics dm LEFT JOIN user_retention ur ON dm.day = ur.day AND dm.city = ur.city ORDER BY dm.day DESC, dm.city"
      },
      "Columns": [
        {
          "Name": "day",
          "Type": "DATETIME"
        },
        {
          "Name": "city",
          "Type": "STRING"
        },
        {
          "Name": "active_users",
          "Type": "INTEGER"
        },
        {
          "Name": "total_rides",
          "Type": "INTEGER"
        },
        {
          "Name": "revenue",
          "Type": "DECIMAL"
        },
        {
          "Name": "avg_rating",
          "Type": "DECIMAL"
        },
        {
          "Name": "completed_rides",
          "Type": "INTEGER"
        },
        {
          "Name": "cancelled_rides",
          "Type": "INTEGER"
        },
        {
          "Name": "returning_users",
          "Type": "INTEGER"
        },
        {
          "Name": "retention_rate",
          "Type": "DECIMAL"
        }
      ]
    }
