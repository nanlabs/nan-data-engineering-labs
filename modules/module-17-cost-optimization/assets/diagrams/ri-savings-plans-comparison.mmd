    subgraph "Utilization Breakeven"
        G1["On-Demand baseline: 100%
        RI/SP breakeven: ~15-20% utilization"]

        G2["Example: $6,000 Standard RI (3yr)
        Breakeven: 20% usage = 146 hours/month
        Profitable: >146 hours/month
        Break-even: ≤146 hours (use On-Demand)"]

        G3["Recommendation:
        >50% monthly utilization → RI/SP
        20-50% utilization → Mix RI/SP + On-Demand
        <20% utilization → On-Demand only"]
    end

    subgraph "Hybrid Strategy Example"
        H1["Data Platform: 50 EC2 instances
        Baseline load: 30 instances (24/7)
        Peak load: +20 instances (business hours)"]

        H2["Optimal Mix:
        30 instances → Standard RI (3yr)
        10 instances → Compute Savings Plan (1yr)
        10 instances → On-Demand"]

        H3["Cost Breakdown:
        30 × $1,953 = $58,590 (RI)
        10 × $3,066 = $30,660 (SP)
        10 × $2,000 (50% util) = $20,000 (On-Demand)
        Annual total: $109,250
        vs All On-Demand: $336,384
        Savings: $227,134 (67%)"]
    end

    H1 --> H2 --> H3

    subgraph "Spot Instance Best Practices"
        I1["✅ Use for batch processing
        EMR, Glue, ECS Batch"]

        I2["✅ Implement checkpointing
        Save state every 5-10 minutes"]

        I3["✅ Diversify instance types
        Request multiple families (m5, c5, r5)"]

        I4["✅ Handle interruptions
        EC2 Spot Instance Interruption Notice
        2-minute warning via CloudWatch"]

        I5["✅ Target 70-80% Spot
