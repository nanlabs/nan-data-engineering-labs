    subgraph "Automated Remediation Workflows"
        L1["Workflow 1: Budget Exceeded
        Trigger: 120% budget threshold
        Actions:
        1. Stop all dev/test EC2 instances
        2. Scale down non-prod RDS to smaller instances
        3. Send executive alert
        4. Create JIRA ticket for cost review"]

        L2["Workflow 2: Untagged Resources
        Trigger: Resource created without tags
        Actions:
        1. Auto-tag with creator info
        2. If auto-tag fails, send alert to owner
        3. After 7 days, restrict access
        4. After 30 days, terminate (dev/test only)"]

        L3["Workflow 3: Idle Resource Detected
        Trigger: <5% CPU for 7 days
        Actions:
        1. Snapshot instance (backup)
        2. Send warning email (3-day grace)
        3. Stop instance if no response
        4. After 14 days stopped, create AMI and terminate"]

        L4["Workflow 4: Cost Anomaly
        Trigger: Spend spike >25%
        Actions:
        1. Identify root cause (service, account, region)
        2. Send detailed report to owner
        3. If >$5K anomaly, page on-call engineer
        4. Create incident in PagerDuty
        5. Post to #ops-alerts Slack channel"]
    end

