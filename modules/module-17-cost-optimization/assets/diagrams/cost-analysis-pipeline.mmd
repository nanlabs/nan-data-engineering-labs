    B1 --> D1
    B2 --> D1

    subgraph "Cost Analysis Queries"
        E1["Top 10 Services by Cost
        SELECT line_item_product_code,
               SUM(line_item_unblended_cost) as cost
        FROM cur
        WHERE year='2024' AND month='01'
        GROUP BY line_item_product_code
        ORDER BY cost DESC
        LIMIT 10"]

        E2["Cost by Environment
        SELECT resource_tags_user_environment,
               SUM(line_item_unblended_cost) as cost
        FROM cur
        WHERE year='2024' AND month='01'
        GROUP BY resource_tags_user_environment"]

        E3["Daily Cost Trend
        SELECT line_item_usage_start_date,
               SUM(line_item_unblended_cost) as daily_cost
        FROM cur
        WHERE year='2024' AND month='01'
        GROUP BY line_item_usage_start_date
        ORDER BY line_item_usage_start_date"]

        E4["Untagged Resources
        SELECT line_item_resource_id,
               line_item_product_code,
               SUM(line_item_unblended_cost) as cost
        FROM cur
        WHERE resource_tags_user_cost_center IS NULL
          AND line_item_unblended_cost > 0
        GROUP BY line_item_resource_id, line_item_product_code
        ORDER BY cost DESC"]
    end

    C4 --> E1
    C4 --> E2
    C4 --> E3
    C4 --> E4

    subgraph "Cost Anomaly Detection"
        F1["Detect Spikes > 20%
        WITH daily_costs AS (
          SELECT DATE(line_item_usage_start_date) as date,
                 SUM(line_item_unblended_cost) as cost
          FROM cur
          GROUP BY DATE(line_item_usage_start_date)
        ),
        cost_with_prev AS (
          SELECT date, cost,
                 LAG(cost, 1) OVER (ORDER BY date) as prev_cost
          FROM daily_costs
        )
        SELECT date, cost, prev_cost,
               (cost - prev_cost) / prev_cost * 100 as pct_change
        FROM cost_with_prev
        WHERE (cost - prev_cost) / prev_cost > 0.20"]

        F2[AWS Cost Anomaly Detection ML]
        F3[CloudWatch Alarm]
        F4[SNS Alert]
    end

    C4 --> F1
    B1 --> F2
    F1 --> F3
    F2 --> F3
    F3 --> F4

