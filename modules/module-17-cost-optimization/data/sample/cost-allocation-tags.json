  "automation_examples": {
    "tag_enforcement_scp": {
      "description": "Service Control Policy to require tags on resource creation",
      "policy": {
        "Version": "2012-10-17",
        "Statement": [
          {
            "Effect": "Deny",
            "Action": [
              "ec2:RunInstances",
              "rds:CreateDBInstance",
              "s3:CreateBucket"
            ],
            "Resource": "*",
            "Condition": {
              "StringNotLike": {
                "aws:RequestTag/CostCenter": "CC-*"
              }
            }
          }
        ]
      }
    },
    "auto_tag_lambda": {
      "description": "Lambda function to auto-tag resources with default values",
      "trigger": "CloudTrail event for RunInstances, CreateDBInstance, CreateBucket",
      "tags_applied": {
        "CreatedBy": "${aws:username}",
        "CreatedDate": "${event.responseElements.launchTime}",
        "ManagedBy": "Terraform"
      }
    },
    "tag_compliance_report": {
      "description": "Daily report of resources missing required tags",
      "schedule": "cron(0 9 * * ? *)",
      "output": "CSV report sent to finops@company.com",
      "includes": ["resource_id", "resource_type", "missing_tags", "estimated_monthly_cost"]
    }
  },
