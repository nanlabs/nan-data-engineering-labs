  "tagging_automation_scripts": {
    "bulk_tag_resources": {
      "description": "Tag multiple resources at once using AWS CLI",
      "command": "aws resourcegroupstaggingapi tag-resources --resource-arn-list $(cat resource-arns.txt) --tags CostCenter=CC-12345,Team=Engineering",
      "use_case": "Apply tags to existing resources in bulk"
    },
    "tag_compliance_check": {
      "description": "Check tag compliance across all resources",
      "command": "aws resourcegroupstaggingapi get-resources --tag-filters Key=CostCenter,Values='' | jq '.ResourceTagMappingList | length'",
      "use_case": "Find resources missing CostCenter tag"
    },
    "enforce_tags_on_creation": {
      "description": "Use AWS Config rule to check tags on new resources",
      "config_rule": "required-tags",
      "parameters": {
        "tag1Key": "CostCenter",
        "tag2Key": "Team",
