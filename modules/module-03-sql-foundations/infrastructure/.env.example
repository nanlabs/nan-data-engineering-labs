# =====================================================
# PostgreSQL Configuration
# =====================================================
# Copy this file to .env and adjust values as needed
# DO NOT commit .env to version control!
# =====================================================

# Database Configuration
POSTGRES_DB=ecommerce
POSTGRES_USER=dataengineer
POSTGRES_PASSWORD=training123

# PostgreSQL Port (change if 5432 is already in use)
POSTGRES_PORT=5432

# =====================================================
# pgAdmin Configuration (optional)
# =====================================================
# Only used when starting with --profile gui
# Access at: http://localhost:5050

PGADMIN_EMAIL=admin@training.local
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# =====================================================
# Connection String Examples
# =====================================================
# Use these in your Python scripts or SQL clients

# Standard connection string:
# postgresql://dataengineer:training123@localhost:5432/ecommerce

# For Python psycopg2:
# conn = psycopg2.connect(
#     host="localhost",
#     port=5432,
#     database="ecommerce",
#     user="dataengineer",
#     password="training123"
# )

# For SQLAlchemy:
# engine = create_engine('postgresql://dataengineer:training123@localhost:5432/ecommerce')

# For psql command line:
# psql -h localhost -p 5432 -U dataengineer -d ecommerce

# =====================================================
# Security Notes
# =====================================================
# For production environments:
# - Use strong passwords (20+ characters)
# - Never expose PostgreSQL port to the internet
# - Use environment-specific .env files
# - Enable SSL/TLS connections
# - Implement proper user roles and permissions
# - Regularly rotate passwords
# =====================================================
