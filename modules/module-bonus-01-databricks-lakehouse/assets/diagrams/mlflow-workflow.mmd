## MLflow Workflow Stages Explained

### Stage 1: Data Preparation
```python
# Load and prepare data
df = spark.table("customer_data")

# Feature engineering
features_df = df \
    .withColumn("tenure_years", col("tenure_months") / 12) \
    .withColumn("revenue_per_month", col("total_revenue") / col("tenure_months"))

# Train/test split
train_df, test_df = features_df.randomSplit([0.8, 0.2], seed=42)
```

---

### Stage 2: Experiment Tracking
```python
import mlflow
import mlflow.sklearn
from sklearn.ensemble import RandomForestClassifier

# Start MLflow run
with mlflow.start_run(run_name="rf_baseline"):
    # Log parameters
    params = {"n_estimators": 100, "max_depth": 10}
    mlflow.log_params(params)

    # Train model
    model = RandomForestClassifier(**params)
    model.fit(X_train, y_train)

    # Evaluate
    accuracy = model.score(X_test, y_test)
    mlflow.log_metric("accuracy", accuracy)

    # Log model
    mlflow.sklearn.log_model(model, "model")
```

**MLflow automatically tracks**:
- Git commit hash
- User who ran experiment
- Start/end time
- Code version
- Environment (Python packages)

---

### Stage 3: Hyperparameter Tuning
```python
param_grid = {
    "n_estimators": [50, 100, 200],
    "max_depth": [5, 10, 15]
}

best_auc = 0
best_params = None

for n_est in param_grid["n_estimators"]:
    for depth in param_grid["max_depth"]:
        with mlflow.start_run(run_name=f"rf_n{n_est}_d{depth}"):
            model = RandomForestClassifier(n_estimators=n_est, max_depth=depth)
            model.fit(X_train, y_train)

            auc = roc_auc_score(y_test, model.predict_proba(X_test)[:, 1])
            mlflow.log_metric("roc_auc", auc)

            if auc > best_auc:
                best_auc = auc
                best_params = {"n_estimators": n_est, "max_depth": depth}
                mlflow.sklearn.log_model(model, "model")

print(f"Best: {best_params} with AUC {best_auc}")
```

**View in UI**: MLflow Experiments page shows all runs sorted by metric.

---

### Stage 4: Model Registry
```python
# Get best run
best_run = mlflow.search_runs(
    order_by=["metrics.roc_auc DESC"],
    max_results=1
).iloc[0]

# Register model
model_uri = f"runs:/{best_run.run_id}/model"
mv = mlflow.register_model(model_uri, "churn_prediction_model")

print(f"Registered model version {mv.version}")

# Add metadata
from mlflow.tracking import MlflowClient
client = MlflowClient()

client.update_model_version(
    name="churn_prediction_model",
    version=mv.version,
    description="Random Forest model trained on 2024-Q1 data. ROC-AUC: 0.97"
)

client.set_model_version_tag(
    name="churn_prediction_model",
    version=mv.version,
    key="training_date",
    value="2024-03-09"
)
```

---

### Stage 5: Stage Transitions
```python
# Transition to Staging
client.transition_model_version_stage(
    name="churn_prediction_model",
    version=mv.version,
    stage="Staging"
)

# Test in staging environment
# ... validation tests ...

# Transition to Production
client.transition_model_version_stage(
    name="churn_prediction_model",
    version=mv.version,
    stage="Production",
    archive_existing_versions=True  # Move old prod version to Archived
)
```

**Stages**:
- **None**: Newly registered
- **Staging**: Pre-production testing
- **Production**: Serving live traffic
- **Archived**: Old versions (inactive)

---

### Stage 6: Deployment Patterns

#### Batch Inference
```python
# Load production model
model = mlflow.sklearn.load_model("models:/churn_prediction_model/Production")

# Score new customers
new_customers = spark.table("new_customers")
predictions = model.predict(new_customers.toPandas())

# Save predictions
predictions_df = new_customers.withColumn("churn_prediction", predictions)
predictions_df.write.format("delta").save("/predictions/churn")
```

#### Real-Time Serving
```python
# Enable model serving in Databricks UI
# Get API endpoint
endpoint = "https://<workspace>/model/churn_prediction_model/Production/invocations"

# Call API
import requests
response = requests.post(
    endpoint,
    headers={"Authorization": f"Bearer {token}"},
    json={"dataframe_records": [{"feature1": 10, "feature2": 20}]}
)

prediction = response.json()
```

#### Streaming Inference
```python
# Load streaming data
stream = spark.readStream.format("delta").load("/streaming/customers")

# Define UDF for model inference
model = mlflow.sklearn.load_model("models:/churn_prediction_model/Production")

@pandas_udf("double")
def predict_churn(features: pd.Series) -> pd.Series:
    return pd.Series(model.predict(features))

# Apply predictions
predictions_stream = stream.withColumn("churn_prob", predict_churn(col("features")))

# Write to Delta
predictions_stream.writeStream.format("delta").start("/predictions/streaming")
```

---

### Stage 7: Monitoring & Retraining

```python
# Monitor model performance
predictions_df = spark.table("predictions.churn")

# Calculate metrics
actual_churn = predictions_df.select("actual_churn").collect()
predicted_churn = predictions_df.select("churn_prediction").collect()

current_auc = roc_auc_score(actual_churn, predicted_churn)
baseline_auc = 0.97

# Detect drift
if current_auc < baseline_auc - 0.05:
    print("🚨 ALERT: Model drift detected!")
    print(f"   Baseline: {baseline_auc:.3f}")
    print(f"   Current: {current_auc:.3f}")

    # Trigger retraining
    # ... retrain_pipeline() ...

    # Register new version
    new_model_uri = f"runs:/{new_run_id}/model"
    mlflow.register_model(new_model_uri, "churn_prediction_model")

    # A/B test new version
    # ... gradual rollout ...
```

