# Módulo 11: Infrastructure as Code - .gitignore

# ============================================
# TERRAFORM
# ============================================

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which might contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Terraform lock file (opcional - algunos proyectos lo versionan)
# .terraform.lock.hcl

# ============================================
# AWS CREDENTIALS
# ============================================

# AWS credentials file
.aws/
aws_credentials
*.pem
*.key

# Environment variables
.env
.env.local
.env.*.local

# ============================================
# PYTHON
# ============================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ============================================
# IDEs Y EDITORES
# ============================================

# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ============================================
# SISTEMA OPERATIVO
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.directory

# ============================================
# LOGS Y TEMPORALES
# ============================================

*.log
*.tmp
*.temp
tmp/
temp/
logs/

# ============================================
# BACKUPS
# ============================================

*.backup
*.bak
*.old

# ============================================
# OUTPUTS Y REPORTES
# ============================================

output/
reports/
*.tfplan
*.tfplan.json

# Cost estimation reports
cost-report/
infracost-report.json

# ============================================
# DATOS SENSIBLES
# ============================================

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Certificates
*.crt
*.pem
*.p12
*.pfx

# Secrets
secrets.yaml
secrets.json
.secrets/

# ============================================
# LOCALSTACK Y TESTING
# ============================================

.localstack/
localstack-data/

# ============================================
# DOCUMENTACIÓN GENERADA
# ============================================

docs/_build/
site/
