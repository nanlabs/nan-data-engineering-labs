    %% Sample Audit Queries
    subgraph "Athena Audit Queries"
        QUERY["-- Who accessed sensitive S3 bucket?<br/>SELECT useridentity.principalid, eventtime, sourceipaddress<br/>FROM cloudtrail_logs<br/>WHERE eventname IN ('GetObject', 'PutObject')<br/>  AND requestparameters LIKE '%sensitive-data%'<br/>  AND eventtime > current_date - interval '30' day;<br/><br/>-- Failed login attempts<br/>SELECT COUNT(*), useridentity.principalid<br/>FROM cloudtrail_logs<br/>WHERE eventname = 'ConsoleLogin'<br/>  AND errorcode = 'Failed authentication'<br/>GROUP BY useridentity.principalid<br/>HAVING COUNT(*) > 10;"]:::query
    end

    classDef query fill:#F39C12,stroke:#E67E22,stroke-width:2px,color:#fff,text-align:left

    AUD1 --> QUERY

