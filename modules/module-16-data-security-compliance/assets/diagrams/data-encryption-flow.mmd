graph TB
    %% Data Encryption Flow - KMS & Envelope Encryption

    subgraph "Plain Text Data"
        PT[Customer Data<br/>SSN, Credit Card, Email]:::plaintext
    end

    subgraph "AWS Key Management Service (KMS)"
        KMS1[Customer Master Key<br/>CMK - AES-256]:::kms
        KMS2[Key Policy<br/>Who can use key?]:::kms
        KMS3[Key Rotation<br/>Auto-rotate every year]:::kms
        KMS4[CloudHSM<br/>FIPS 140-2 Level 3]:::kms
    end

    PT --> KMS1
    KMS1 --> KMS2
    KMS2 --> KMS3
    KMS3 -.->|"High security"| KMS4

    subgraph "Envelope Encryption"
        EE1[1. Generate Data Key<br/>KMS GenerateDataKey API]:::envelope
        EE2[2. Encrypt Data<br/>With plain-text data key]:::envelope
        EE3[3. Store Encrypted Data<br/>+ Encrypted data key]:::envelope
        EE4[4. Decrypt Data Key<br/>KMS Decrypt API]:::envelope
        EE5[5. Decrypt Data<br/>With plain-text data key]:::envelope
    end

    KMS1 --> EE1
    EE1 --> EE2
    EE2 --> EE3
    EE3 --> EE4
    EE4 --> EE5

    subgraph "Encryption at Rest"
        ER1[S3 Bucket<br/>SSE-KMS / SSE-S3 / SSE-C]:::rest
        ER2[RDS Database<br/>TDE with KMS]:::rest
        ER3[DynamoDB Table<br/>Encryption at rest]:::rest
        ER4[Redshift Cluster<br/>Hardware encryption]:::rest
        ER5[EBS Volume<br/>Block-level encryption]:::rest
    end

    EE3 --> ER1
    EE3 --> ER2
    EE3 --> ER3
    EE3 --> ER4
    EE3 --> ER5

    subgraph "Encryption in Transit"
        ET1[TLS/SSL 1.3<br/>HTTPS Endpoints]:::transit
        ET2[VPC Endpoints<br/>Private connectivity]:::transit
        ET3[PrivateLink<br/>No internet exposure]:::transit
        ET4[VPN/Direct Connect<br/>On-prem to AWS]:::transit
    end

    ER1 --> ET1
    ER2 --> ET1
    ET1 --> ET2
    ET2 --> ET3
    ET3 -.->|"Hybrid"| ET4

    subgraph "Client-Side Encryption"
        CE1[AWS Encryption SDK<br/>Encrypt before upload]:::client
        CE2[Application-Level<br/>Custom encryption]:::client
        CE3[Field-Level Encryption<br/>CloudFront]:::client
    end

    PT -.->|"High security"| CE1
    CE1 --> CE2
    CE2 --> CE3
    CE3 --> ER1

    %% Styling
    classDef plaintext fill:#E74C3C,stroke:#C0392B,stroke-width:3px,color:#fff
    classDef kms fill:#FF9900,stroke:#CC7A00,stroke-width:3px,color:#fff
    classDef envelope fill:#3498DB,stroke:#2980B9,stroke-width:3px,color:#fff
    classDef rest fill:#27AE60,stroke:#229954,stroke-width:3px,color:#fff
    classDef transit fill:#9B59B6,stroke:#8E44AD,stroke-width:3px,color:#fff
    classDef client fill:#F39C12,stroke:#E67E22,stroke-width:3px,color:#fff

    %% Encryption Methods Comparison
    subgraph "S3 Encryption Options"
        S3ENC["SSE-S3: AWS-managed keys (AES-256)<br/>  • Pros: Simple, no cost<br/>  • Cons: No key rotation control<br/><br/>SSE-KMS: Customer Master Keys<br/>  • Pros: Key rotation, audit trail<br/>  • Cons: API rate limits<br/><br/>SSE-C: Customer-provided keys<br/>  • Pros: Full control<br/>  • Cons: Manage keys yourself<br/><br/>Client-Side: Encrypt before upload<br/>  • Pros: Maximum security<br/>  • Cons: Complex implementation"]:::comparison
    end

    classDef comparison fill:#34495E,stroke:#2C3E50,stroke-width:2px,color:#fff,text-align:left

    ER1 --> S3ENC

    %% Key Rotation
    subgraph "KMS Key Rotation"
        ROT["Automatic Rotation:<br/>• Every 365 days<br/>• Old keys still work (decryption)<br/>• New data uses new key<br/><br/>Manual Rotation:<br/>• Create new CMK<br/>• Update aliases<br/>• Re-encrypt data (optional)<br/><br/>Rotation Strategy:<br/>• Compliance: Annual<br/>• High Security: Quarterly<br/>• Standard: Annual"]:::rotation
    end

    classDef rotation fill:#16A085,stroke:#138D75,stroke-width:2px,color:#fff,text-align:left

    KMS3 --> ROT

    %% Performance Impact
    subgraph "Performance & Cost"
        PERF["Encryption Performance:<br/>• S3 SSE-KMS: <5% overhead<br/>• RDS TDE: <10% overhead<br/>• DynamoDB: <2% overhead<br/>• Client-side: 10-20% overhead<br/><br/>Cost (per 10K requests):<br/>• SSE-S3: $0 (included)<br/>• SSE-KMS: $0.03<br/>• CloudHSM: $1.45/hour<br/><br/>KMS API Limits:<br/>• Shared: 5,500 req/sec<br/>• Dedicated: 10,000 req/sec"]:::perf
    end

    classDef perf fill:#1ABC9C,stroke:#17A589,stroke-width:2px,color:#fff,text-align:left

    %% Compliance Requirements
    subgraph "Compliance Frameworks"
        COMP["FIPS 140-2: KMS (Level 2), CloudHSM (Level 3)<br/>HIPAA: Encryption at rest + transit (required)<br/>PCI-DSS: Strong cryptography (AES-256)<br/>GDPR: Encryption as safeguard<br/>SOC 2: Key management controls"]:::compliance
    end

    classDef compliance fill:#E67E22,stroke:#CA6F1E,stroke-width:2px,color:#fff,text-align:left
