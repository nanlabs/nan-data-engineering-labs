graph TB
    %% PII Detection & Masking - Data Protection Workflow

    subgraph "Raw Data with PII"
        RAW["Customer Records:<br/>name: John Doe<br/>ssn: 123-45-6789<br/>email: john@example.com<br/>phone: +1-555-123-4567<br/>credit_card: 4532-1234-5678-9010"]:::raw
    end

    subgraph "PII Detection"
        DET1[Amazon Macie<br/>S3 Bucket Scan]:::detect
        DET2[Amazon Comprehend<br/>NLP Entity Recognition]:::detect
        DET3[AWS Glue<br/>FindMatches ML]:::detect
        DET4[Regex Patterns<br/>Custom Rules]:::detect
    end

    RAW --> DET1
    RAW --> DET2
    RAW --> DET3
    RAW --> DET4

    subgraph "PII Classification"
        CLASS["High Sensitivity:<br/>• SSN<br/>• Credit Card<br/>• Passport Number<br/><br/>Medium Sensitivity:<br/>• Email<br/>• Phone<br/>• Address<br/><br/>Low Sensitivity:<br/>• Name<br/>• Age<br/>• Gender"]:::classify
    end

    DET1 --> CLASS
    DET2 --> CLASS
    DET3 --> CLASS
    DET4 --> CLASS

    subgraph "Masking Strategies"
        MASK1[Full Masking<br/>123-45-6789 → ***-**-****]:::mask
        MASK2[Partial Masking<br/>4532-1234-5678-9010 → ****-****-****-9010]:::mask
        MASK3[Hashing<br/>john@example.com → 8f14e45fceea167a]:::mask
        MASK4[Tokenization<br/>SSN → TOKEN_ABC123XYZ]:::mask
    end

    CLASS --> MASK1
    CLASS --> MASK2
    CLASS --> MASK3
    CLASS --> MASK4

    subgraph "Dynamic Data Masking"
        DDM1["Redshift Dynamic DDM:<br/>CREATE MASKING POLICY ssn_mask<br/>USING ('XXX-XX-' || RIGHT(ssn, 4));<br/><br/>Apply to Column:<br/>ALTER TABLE customers<br/>ATTACH MASKING POLICY ssn_mask<br/>ON ssn TO ROLE analyst;"]:::ddm

        DDM2["Athena View-Based Masking:<br/>CREATE VIEW customers_masked AS<br/>SELECT<br/>  customer_id,<br/>  name,<br/>  CASE<br/>    WHEN current_user = 'admin' THEN ssn<br/>    ELSE 'XXX-XX-' || SUBSTR(ssn, -4)<br/>  END as ssn<br/>FROM customers;"]:::ddm
    end

    MASK1 --> DDM1
    MASK2 --> DDM2

    subgraph "Tokenization Service"
        TOK1[Token Vault<br/>DynamoDB]:::token
        TOK2[Mapping Table<br/>SSN ↔ Token]:::token
        TOK3[Detokenization API<br/>Authorized only]:::token
    end

    MASK4 --> TOK1
    TOK1 --> TOK2
    TOK2 --> TOK3

    subgraph "Anonymization Techniques"
        ANON1["K-Anonymity:<br/>• Group records (k=5)<br/>• Suppress unique IDs<br/>• Generalize age (25 → 20-30)"]:::anon

        ANON2["Differential Privacy:<br/>• Add statistical noise<br/>• ε-differential privacy (ε=0.1)<br/>• Preserve aggregate accuracy"]:::anon

        ANON3["Pseudonymization:<br/>• Replace with fake data<br/>• Consistent across datasets<br/>• Reversible with key"]:::anon
    end

    CLASS --> ANON1
    CLASS --> ANON2
    CLASS --> ANON3

    subgraph "Output Data"
        OUT1[Masked Data<br/>For Analytics]:::output
        OUT2[Anonymous Data<br/>For ML Training]:::output
        OUT3[Tokenized Data<br/>For Storage]:::output
        OUT4[Audit Log<br/>Who accessed what]:::output
    end

    DDM1 --> OUT1
    ANON2 --> OUT2
    TOK3 --> OUT3
    DET1 --> OUT4

