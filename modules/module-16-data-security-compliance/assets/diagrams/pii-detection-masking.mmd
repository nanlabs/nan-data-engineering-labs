    %% PII Detection Accuracy
    subgraph "Detection Methods Comparison"
        COMP["Macie (ML):<br/>• Accuracy: 95%+<br/>• Cost: $1/GB scanned<br/>• Best for: S3 data discovery<br/><br/>Comprehend (NLP):<br/>• Accuracy: 90%+<br/>• Cost: $0.0005/100 chars<br/>• Best for: Text documents<br/><br/>Regex (Rules):<br/>• Accuracy: 80% (depends on patterns)<br/>• Cost: Free<br/>• Best for: Known formats (SSN, CC)"]:::comp
    end

    classDef comp fill:#E67E22,stroke:#CA6F1E,stroke-width:2px,color:#fff,text-align:left

    DET4 --> COMP

    %% GDPR Compliance
    subgraph "GDPR Right to Erasure"
        GDPR["1. User requests deletion<br/>2. Identify all PII records<br/>3. Pseudonymize (if retention needed)<br/>4. Delete original data<br/>5. Update audit trail<br/>6. Confirm deletion (30 days)"]:::gdpr
    end

    classDef gdpr fill:#2C3E50,stroke:#1C2833,stroke-width:2px,color:#fff,text-align:left

    OUT4 --> GDPR

    %% Real-World Examples
    subgraph "Industry Examples"
        EX["Healthcare (HIPAA):<br/>• Mask patient SSN for researchers<br/>• K-anonymity for medical records<br/><br/>Finance (PCI-DSS):<br/>• Tokenize credit cards<br/>• Store only last 4 digits<br/><br/>Retail (GDPR):<br/>• Pseudonymize customer IDs<br/>• Delete on request (30 days)"]:::example
    end

    classDef example fill:#7ED321,stroke:#5A9E18,stroke-width:2px,color:#fff,text-align:left
