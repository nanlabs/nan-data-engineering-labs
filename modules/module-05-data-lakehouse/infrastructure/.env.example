# ============================================================================
# Environment Variables - Data Lakehouse Infrastructure
# ============================================================================
# Copy this file to .env and adjust values as needed
# ============================================================================

# ----------------------------------------------------------------------------
# MinIO Configuration (S3-compatible storage)
# ----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_REGION=us-east-1
MINIO_PORT_API=9000
MINIO_PORT_CONSOLE=9001

# ----------------------------------------------------------------------------
# PostgreSQL Configuration (Hive Metastore backend)
# ----------------------------------------------------------------------------
POSTGRES_USER=hive
POSTGRES_PASSWORD=hive
POSTGRES_DB=metastore
POSTGRES_PORT=5432

# ----------------------------------------------------------------------------
# Spark Configuration
# ----------------------------------------------------------------------------
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8080
SPARK_WORKER_WEBUI_PORT=8081
SPARK_WORKER_CORES=2
SPARK_WORKER_MEMORY=4G
SPARK_DRIVER_MEMORY=2G
SPARK_EXECUTOR_MEMORY=2G

# ----------------------------------------------------------------------------
# Jupyter Configuration
# ----------------------------------------------------------------------------
JUPYTER_PORT=8888
JUPYTER_ENABLE_LAB=yes

# ----------------------------------------------------------------------------
# Hive Metastore Configuration
# ----------------------------------------------------------------------------
HIVE_METASTORE_PORT=9083

# ----------------------------------------------------------------------------
# Networking
# ----------------------------------------------------------------------------
DOCKER_NETWORK=lakehouse-network

# ============================================================================
# Notes:
# ============================================================================
# 1. These are DEFAULT values for local development
# 2. For production, use secure passwords and restrict access
# 3. Adjust memory settings based on your machine's capacity
# 4. Do NOT commit .env file with real credentials to git
# ============================================================================
