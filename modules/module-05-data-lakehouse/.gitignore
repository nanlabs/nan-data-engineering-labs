# ============================================================================
# .gitignore for Module 05: Data Lakehouse Architecture
# ============================================================================

# ------------------------------
# Python
# ------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
env/
ENV/
.venv/

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ------------------------------
# Spark & Delta Lake
# ------------------------------
# Spark logs and temporary files
spark-warehouse/
metastore_db/
derby.log
*.log

# Delta Lake transaction logs (only ignore generated, not committed ones)
_delta_log/
*.checkpoint.parquet

# Spark temporary directories
.spark/
spark-events/

# Checkpoints and state
checkpoints/
checkpoint/
state/

# ------------------------------
# Data Files
# ------------------------------
# Raw data (generated locally)
data/raw/*.csv
data/raw/*.json
data/raw/*.parquet

# Processed data (generated by pipelines)
data/processed/
data/bronze/
data/silver/
data/gold/

# Temporary data
data/temp/
data/tmp/

# Keep schemas and scripts
!data/schemas/
!data/scripts/

# ------------------------------
# Iceberg
# ------------------------------
# Iceberg metadata (generated)
iceberg-warehouse/
warehouse/

# ------------------------------
# Jupyter
# ------------------------------
.ipynb_checkpoints
*.ipynb_checkpoints/

# Jupyter Lab workspace
.jupyter/
.jupyter-workspace/

# ------------------------------
# Docker & MinIO
# ------------------------------
# Docker volumes and data
docker-volumes/
minio-data/
postgres-data/

# Docker logs
*.log

# MinIO local storage
.minio/
.minio.sys/

# ------------------------------
# IDE & Editors
# ------------------------------
# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ------------------------------
# OS Files
# ------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# ------------------------------
# Logs & Reports
# ------------------------------
logs/
*.log
test-reports/
pytest_report.html
assets/

# Memory profiling
*.prof
*.lprof

# ------------------------------
# Environment & Secrets
# ------------------------------
.env
.env.local
*.env
secrets/
*.secret

# AWS credentials (should never be committed)
.aws/
credentials

# ------------------------------
# Temporary Files
# ------------------------------
*.tmp
*.temp
*.bak
*.swp
temp/
tmp/

# ------------------------------
# Build Artifacts
# ------------------------------
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------
# Documentation Build
# ------------------------------
site/
docs/_build/

# ------------------------------
# Keep These Files
# ------------------------------
# Keep empty directories with .gitkeep
!.gitkeep

# Keep example and template files
!*.example
!*.template

# Keep schema files
!data/schemas/*.json

# Keep documentation
!docs/
!assets/

# Keep scripts
!scripts/*.sh
!scripts/*.py

# ============================================================================
# Notes:
# ============================================================================
#
# This .gitignore is specifically configured for a Data Lakehouse module with:
# - PySpark and Delta Lake
# - Apache Iceberg
# - MinIO (S3-compatible storage)
# - Docker Compose infrastructure
# - Jupyter Lab development environment
#
# Key patterns:
# 1. Ignore all generated data files (raw, processed, bronze, silver, gold)
# 2. Keep schemas and generation scripts (committed to repo)
# 3. Ignore Spark/Delta/Iceberg metadata and transaction logs
# 4. Ignore Docker volumes and MinIO data
# 5. Ignore all logs, temporary files, and test artifacts
#
# To check what will be committed:
#   git status
#   git ls-files
#
# To see what is being ignored:
#   git status --ignored
#
# ============================================================================
